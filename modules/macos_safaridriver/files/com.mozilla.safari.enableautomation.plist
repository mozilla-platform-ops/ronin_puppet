<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mozilla.safari.enableautomation</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/osascript</string>
        <string>/usr/local/bin/safari-enable-remote-automation.applescript</string>
    </array>
    <key>StandardOutPath</key>
    <string>/tmp/safari-enable-automation.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/safari-enable-automation.err</string>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
