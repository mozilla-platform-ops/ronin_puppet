#!/usr/bin/env python3
# Read-only health check for Linux Taskcluster generic-worker hosts.
# Usage: gwhc [--json]
# Exit 0 if all checks pass/warn, 1 if any fail.

import argparse
import datetime
import email.utils
import json
import os
import re
import socket
import subprocess
import sys
import urllib.request

# ── constants ─────────────────────────────────────────────────────────────────

PUPPET_METADATA = "/etc/puppet/last_run_metadata.json"
PUPPET_DONE_SENTINEL = "/tmp/puppet_run_done"
PUPPET_MAX_AGE_HOURS = 24

TASK_DIR = "/home/cltbld/tasks"
TASK_DIR_WARN_GB = 20
TASK_DIR_FAIL_GB = 40

GW_LOG_DIR = "/var/log/genericworker"
GW_LOG_STALE_MINUTES = 15

CLOCK_REFERENCE_URL = "https://taskcluster.net"
CLOCK_WARN_SECONDS = 60
CLOCK_FAIL_SECONDS = 300

DISK_MOUNTS = ["/", "/var", "/home"]
DISK_FAIL_FREE_GB = 5
DISK_FAIL_FREE_PCT = 10

_CLEANER = "/usr/sbin/cltbld-and-apt-cleaner.sh"

PASS = "pass"
WARN = "warn"
FAIL = "fail"

# ── display ───────────────────────────────────────────────────────────────────

_use_color = sys.stdout.isatty()


def _c(text, code):
    return f"\033[{code}m{text}\033[0m" if _use_color else text


def green(t):
    return _c(t, "32")


def yellow(t):
    return _c(t, "33")


def red(t):
    return _c(t, "31")


def bold(t):
    return _c(t, "1")


# ── process detection (stdlib /proc, no psutil) ───────────────────────────────

def find_procs_by_name(name):
    """Return list of pids whose comm or argv[0] basename matches name."""
    pids = []
    try:
        for entry in os.scandir("/proc"):
            if not entry.name.isdigit():
                continue
            pid = int(entry.name)
            try:
                with open(f"/proc/{pid}/comm") as f:
                    if f.read().strip() == name:
                        pids.append(pid)
                        continue
            except OSError:
                continue
            try:
                with open(f"/proc/{pid}/cmdline", "rb") as f:
                    argv0 = f.read().split(b"\x00")[0]
                if os.path.basename(argv0.decode("utf-8", "replace")) == name:
                    pids.append(pid)
            except OSError:
                pass
    except OSError:
        pass
    return pids


def _cleaner_running():
    """Return pid of running cltbld-and-apt-cleaner.sh, or None."""
    try:
        for entry in os.scandir("/proc"):
            if not entry.name.isdigit():
                continue
            try:
                with open(f"/proc/{entry.name}/cmdline", "rb") as f:
                    if _CLEANER.encode() in f.read():
                        return int(entry.name)
            except OSError:
                pass
    except OSError:
        pass
    return None


# ── checks ────────────────────────────────────────────────────────────────────

def check_clock_skew():
    cmds = [f"HEAD {CLOCK_REFERENCE_URL}"]
    try:
        req = urllib.request.Request(CLOCK_REFERENCE_URL, method="HEAD")
        with urllib.request.urlopen(req, timeout=5) as resp:
            date_hdr = resp.headers.get("Date")
        if not date_hdr:
            return WARN, "no Date header in response", {"cmds": cmds}
        remote = email.utils.parsedate_to_datetime(date_hdr)
        local = datetime.datetime.now(datetime.timezone.utc)
        skew = abs((local - remote).total_seconds())
        data = {"skew_seconds": round(skew, 1), "reference": CLOCK_REFERENCE_URL, "cmds": cmds}
        if skew > CLOCK_FAIL_SECONDS:
            return FAIL, f"clock skew {skew:.0f}s (>{CLOCK_FAIL_SECONDS}s)", data
        if skew > CLOCK_WARN_SECONDS:
            return WARN, f"clock skew {skew:.0f}s (>{CLOCK_WARN_SECONDS}s)", data
        return PASS, f"skew {skew:.1f}s", data
    except Exception as e:
        return WARN, f"could not reach {CLOCK_REFERENCE_URL}: {e}", {"cmds": cmds}


def check_disk_free():
    mounts = {}
    failures = []
    seen_devs = set()
    for mount in DISK_MOUNTS:
        if not os.path.exists(mount):
            continue
        try:
            dev = os.stat(mount).st_dev
            if dev in seen_devs:
                continue
            seen_devs.add(dev)
            st = os.statvfs(mount)
            total = st.f_frsize * st.f_blocks
            if total == 0:
                continue  # pseudo/automount filesystem
            free = st.f_frsize * st.f_bavail
            pct = free / total * 100
            free_gb = free / 1024 ** 3
            mounts[mount] = {
                "free_gb": round(free_gb, 1),
                "free_pct": round(pct, 1),
                "total_gb": round(total / 1024 ** 3, 1),
            }
            if free_gb < DISK_FAIL_FREE_GB or pct < DISK_FAIL_FREE_PCT:
                failures.append(f"{mount}: {free_gb:.1f}GB ({pct:.0f}% free)")
        except OSError as e:
            mounts[mount] = {"error": str(e)}

    cpid = _cleaner_running()
    data = dict(mounts)
    if cpid:
        data["cleaner_running"] = True
        data["cleaner_pid"] = cpid

    summary = ", ".join(
        f"{m}: {v['free_gb']}GB" for m, v in mounts.items() if "free_gb" in v
    )

    if failures:
        if cpid:
            return WARN, "low disk: " + "; ".join(failures) + " — cleanup running", data
        return FAIL, "low disk: " + "; ".join(failures), data
    if cpid:
        return WARN, f"{summary} — cleanup running (pid {cpid})", data
    return PASS, summary, data


def check_generic_worker_process():
    pids = find_procs_by_name("generic-worker")
    data = {"pids": pids}
    if len(pids) == 0:
        if not os.path.exists(PUPPET_DONE_SENTINEL):
            return WARN, "not running — puppet run still in progress (waiting for sentinel)", data
        return FAIL, "not running", data
    if len(pids) > 1:
        return FAIL, f"{len(pids)} processes found (expected 1): pids {pids}", data

    task_state, task_cmd = _gw_task_state()
    data["task_state"] = task_state
    data["cmds"] = [task_cmd]
    if task_state == "task running":
        nchildren = _proc_descendants(pids[0])
        data["child_procs"] = nchildren
        load1, load5, load15 = os.getloadavg()
        data["load_avg"] = {"1m": round(load1, 2), "5m": round(load5, 2), "15m": round(load15, 2)}
        return WARN, f"running (pid {pids[0]}) — task in progress ({nchildren} child procs, load {load1:.2f}), do not reboot", data
    return PASS, f"running (pid {pids[0]}) — {task_state}", data


def _proc_descendants(root_pid):
    """Return count of all descendant processes of root_pid via /proc PPid."""
    children = {}
    try:
        for entry in os.scandir("/proc"):
            if not entry.name.isdigit():
                continue
            try:
                with open(f"/proc/{entry.name}/status") as f:
                    for line in f:
                        if line.startswith("PPid:"):
                            ppid = int(line.split()[1])
                            children.setdefault(ppid, []).append(int(entry.name))
                            break
            except OSError:
                pass
    except OSError:
        pass

    count = 0
    queue = [root_pid]
    while queue:
        pid = queue.pop()
        kids = children.get(pid, [])
        count += len(kids)
        queue.extend(kids)
    return count


def _gw_task_state():
    cmd = ["journalctl", "-t", "generic-worker", "-n", "50", "--no-pager"]
    cmd_str = " ".join(cmd)
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        lines = r.stdout.strip().splitlines()
        for line in reversed(lines):
            if "No task claimed" in line:
                return "idle", cmd_str
            if "Executing command" in line or "Starting task feature" in line:
                return "task running", cmd_str
        if not lines:
            return "unknown (no journal output)", cmd_str
    except Exception as e:
        return f"unknown (journalctl error: {e})", cmd_str
    return "unknown (no matching log pattern)", cmd_str


def check_worker_runner_reporting():
    # TODO: add --check-tc-api flag to query queue.taskcluster.net for
    # lastDateActive using workerPoolId + workerId from /etc/start-worker.yml.
    pids = find_procs_by_name("start-worker")
    data = {"start_worker_pids": pids, "log_dir": GW_LOG_DIR}

    log_fresh = False
    log_age_min = None

    _use_journal = True
    if os.path.isdir(GW_LOG_DIR):
        try:
            files = [e for e in os.scandir(GW_LOG_DIR) if e.is_file()]
            if files:
                _use_journal = False
                newest = max(files, key=lambda e: e.stat().st_mtime)
                age_s = datetime.datetime.now().timestamp() - newest.stat().st_mtime
                log_age_min = round(age_s / 60, 1)
                data["log_file"] = newest.path
                data["log_age_minutes"] = log_age_min
                log_fresh = log_age_min <= GW_LOG_STALE_MINUTES
        except OSError:
            pass

    if _use_journal:
        # fall back to journalctl when svlogd log dir is absent or empty
        jcmd = ["journalctl", "-t", "generic-worker", "--since", f"{GW_LOG_STALE_MINUTES} minutes ago", "-n", "1", "--no-pager"]
        data["cmds"] = [" ".join(jcmd)]
        try:
            r = subprocess.run(jcmd, capture_output=True, text=True, timeout=5)
            log_fresh = bool(r.stdout.strip())
            data["journal_recent"] = log_fresh
        except Exception as e:
            data["journal_error"] = str(e)

    if not pids:
        return FAIL, "start-worker process not found", data
    if not log_fresh:
        age_str = f"{log_age_min}min" if log_age_min is not None else "unknown"
        return WARN, f"process alive (pid {pids[0]}) but logs {age_str} old", data
    if log_age_min is not None:
        return PASS, f"running (pid {pids[0]}), logs {log_age_min}min old", data
    return PASS, f"running (pid {pids[0]}), logs recent (journal)", data


def _shallow_dir_size(path):
    """Sum sizes of files one level deep inside path (task subdirs)."""
    total = 0
    try:
        with os.scandir(path) as top:
            for entry in top:
                try:
                    if entry.is_dir(follow_symlinks=False):
                        try:
                            with os.scandir(entry.path) as sub:
                                for f in sub:
                                    try:
                                        total += f.stat(follow_symlinks=False).st_size
                                    except OSError:
                                        pass
                        except OSError:
                            pass
                    else:
                        total += entry.stat(follow_symlinks=False).st_size
                except OSError:
                    pass
    except OSError:
        pass
    return total


def check_task_dir_size():
    if not os.path.isdir(TASK_DIR):
        return PASS, f"{TASK_DIR} absent (clean)", {}
    used_gb = _shallow_dir_size(TASK_DIR) / 1024 ** 3
    data = {"task_dir": TASK_DIR, "used_gb": round(used_gb, 2)}
    if used_gb > TASK_DIR_FAIL_GB:
        return FAIL, f"{used_gb:.1f}GB used (>{TASK_DIR_FAIL_GB}GB)", data
    if used_gb > TASK_DIR_WARN_GB:
        return WARN, f"{used_gb:.1f}GB used (>{TASK_DIR_WARN_GB}GB)", data
    return PASS, f"{used_gb:.1f}GB used", data


def _boot_time():
    """Return system boot time as a UTC-aware datetime, or None."""
    try:
        with open("/proc/stat") as f:
            for line in f:
                if line.startswith("btime "):
                    return datetime.datetime.fromtimestamp(
                        int(line.split()[1]), tz=datetime.timezone.utc
                    )
    except OSError:
        pass
    return None


def _puppet_service_state():
    """Return (ActiveState, SubState, cmd_str) from systemctl, or ('unknown', 'unknown', cmd_str)."""
    cmd = ["systemctl", "show", "run-puppet", "--property=ActiveState,SubState", "--no-pager"]
    cmd_str = " ".join(cmd)
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
        props = dict(line.split("=", 1) for line in r.stdout.strip().splitlines() if "=" in line)
        return props.get("ActiveState", "unknown"), props.get("SubState", "unknown"), cmd_str
    except Exception:
        return "unknown", "unknown", cmd_str


def check_puppet():
    data = {"metadata_path": PUPPET_METADATA}

    active, sub, svc_cmd = _puppet_service_state()
    data["service_state"] = f"{active}/{sub}"
    data["cmds"] = [svc_cmd]

    if active == "activating":
        return WARN, f"run in progress (service={active}/{sub})", data

    boot_ts = _boot_time()
    data["boot_ts"] = boot_ts.isoformat() if boot_ts else None

    if not os.path.exists(PUPPET_METADATA):
        return FAIL, f"{PUPPET_METADATA} not found", data
    try:
        with open(PUPPET_METADATA) as f:
            meta = json.load(f)
    except Exception as e:
        return FAIL, f"could not parse metadata: {e}", data

    for field in ("ts", "success", "exit_code", "duration_s", "git_sha", "role"):
        if field in meta:
            data[field] = meta[field]

    ts_str = meta.get("ts")
    meta_ts = None
    if ts_str:
        try:
            meta_ts = datetime.datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        except Exception:
            pass

    # Metadata predates this boot — puppet hasn't run yet this boot
    if boot_ts and meta_ts and meta_ts < boot_ts:
        data["metadata_from_previous_boot"] = True
        return WARN, f"not yet started this boot (queued, service={active}/{sub})", data

    if not meta.get("success", False):
        exit_code = meta.get('exit_code', '?')
        if active == "active":
            return WARN, f"last run failed (exit_code={exit_code}) — service still running, likely retrying", data
        return FAIL, f"last run failed (exit_code={exit_code}, service={active}/{sub})", data

    if not ts_str:
        return WARN, "success=true but no timestamp", data

    try:
        age_h = (datetime.datetime.now(datetime.timezone.utc) - meta_ts).total_seconds() / 3600
        data["age_hours"] = round(age_h, 1)
        if age_h > PUPPET_MAX_AGE_HOURS:
            return FAIL, f"last run {age_h:.1f}h ago (>{PUPPET_MAX_AGE_HOURS}h)", data
    except Exception as e:
        return WARN, f"could not parse timestamp '{ts_str}': {e}", data

    if not os.path.exists(PUPPET_DONE_SENTINEL):
        data["done_sentinel"] = "missing"
        return WARN, f"success=true but {PUPPET_DONE_SENTINEL} missing", data

    data["done_sentinel"] = "present"
    role = meta.get("role", "?")
    return PASS, f"passed {age_h:.1f}h ago (role={role})", data


# ── report ────────────────────────────────────────────────────────────────────

_CLEANER_HINT = (
    f"sudo {_CLEANER}  (cleans .mozbuild, caches, apt; runs if >70% full)\n"
    "  manual targets: /home/cltbld/.mozbuild  /home/cltbld/caches  "
    "/home/cltbld/tasks  /var/log"
)
_MANUAL_HINT = (
    "cleaner not installed yet (puppet hasn't run); clean manually:\n"
    "  sudo rm -rf /home/cltbld/.mozbuild /home/cltbld/caches "
    "/home/cltbld/file-caches.json /home/cltbld/directory-caches.json\n"
    "  sudo apt-get autoremove -y && sudo apt-get clean"
)

REMEDIATIONS = {
    "disk_free": _CLEANER_HINT if os.path.exists(_CLEANER) else _MANUAL_HINT,
    "task_dir_size": (
        "task dir is large; may fill disk soon\n"
        "  manual: sudo rm -rf /home/cltbld/tasks/*"
    ),
    "generic_worker_process": (
        "check logs: /var/log/genericworker/  "
        "or: journalctl -t generic-worker -n 50"
    ),
    "worker_runner_reporting": (
        "check: /var/log/genericworker/  "
        "or: journalctl -t generic-worker -n 50"
    ),
    "clock_skew": (
        "fix: sudo ntpd -q -g  (forces clock sync, allows large skew)"
    ),
    "puppet": (
        "logs: journalctl -u run-puppet -n 100 --no-pager\n"
        "  metadata: sudo cat /etc/puppet/last_run_metadata.json"
    ),
}

CHECKS = [
    ("clock_skew",              check_clock_skew),
    ("disk_free",               check_disk_free),
    ("task_dir_size",           check_task_dir_size),
    ("puppet",                  check_puppet),
    ("worker_runner_reporting", check_worker_runner_reporting),
    ("generic_worker_process",  check_generic_worker_process),
]


def run_checks():
    results = []
    for name, fn in CHECKS:
        try:
            status, detail, data = fn()
        except Exception as e:
            status, detail, data = FAIL, f"check raised exception: {e}", {}
        cmds = data.pop("cmds", [])
        results.append({"name": name, "status": status, "detail": detail, "data": data, "commands_used": cmds})
    return results


def overall(results):
    return FAIL if any(r["status"] == FAIL for r in results) else PASS


def _by_name(results, name):
    for r in results:
        if r["name"] == name:
            return r
    return None


def summarize(results):
    puppet = _by_name(results, "puppet") or {}
    gwp    = _by_name(results, "generic_worker_process") or {}
    wrr    = _by_name(results, "worker_runner_reporting") or {}
    pdata  = puppet.get("data", {})
    gdata  = gwp.get("data", {})

    disk = _by_name(results, "disk_free") or {}
    if (disk.get("data") or {}).get("cleaner_running"):
        cpid = (disk.get("data") or {}).get("cleaner_pid")
        pid_str = f" (pid {cpid})" if cpid else ""
        return "RECOVERING", f"disk cleanup running{pid_str}, wait for completion"

    if puppet.get("status") == FAIL:
        return "DOWN", puppet.get("detail", "puppet check failed")

    puppet_in_progress = (
        pdata.get("done_sentinel") == "missing"
        or pdata.get("service_state", "").startswith("activating")
        or "retrying" in puppet.get("detail", "")
        or "not yet run this boot" in puppet.get("detail", "")
    )
    if puppet_in_progress:
        if not gdata.get("pids"):
            return "PROVISIONING", "puppet running, g-w waiting to start"
        return "PROVISIONING", "puppet running, g-w up"

    if gwp.get("status") == FAIL:
        return "DEGRADED", f"g-w {gwp.get('detail', 'down')}, puppet ok"
    if wrr.get("status") == FAIL:
        return "DEGRADED", "start-worker missing, g-w ok"

    if gdata.get("task_state") == "task running":
        n = gdata.get("child_procs", "?")
        load1 = (gdata.get("load_avg") or {}).get("1m", "?")
        return "WORKING", f"g-w running task ({n} children, load {load1})"

    ts = gdata.get("task_state", "unknown")
    if ts == "idle":
        return "IDLE", "g-w waiting for tasks"
    return "IDLE", f"g-w up (task state: {ts})"


_STATE_COLOR = {
    "RECOVERING":   yellow,
    "PROVISIONING": yellow,
    "WORKING":      green,
    "IDLE":         green,
    "DEGRADED":     yellow,
    "DOWN":         red,
}


def _format_detail(detail):
    return re.sub(r"(role=)(\S+)", lambda m: m.group(1) + bold(m.group(2)), detail)


def print_json(results, warnings, verbose=False):
    check_warns = [f"{r['name']}: {r['detail']}" for r in results if r["status"] == WARN]
    state, state_description = summarize(results)
    checks = results if verbose else [
        {k: v for k, v in r.items() if k != "commands_used"} for r in results
    ]
    out = {
        "ok": overall(results) == PASS,
        "state": state,
        "state_description": state_description,
        "host": socket.gethostname(),
        "ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "warnings": warnings + check_warns,
        "checks": checks,
    }
    print(json.dumps(out, indent=2))


def print_human(results, warnings, verbose=False):
    for w in warnings:
        print(yellow(f"WARNING: {w}"), file=sys.stderr)

    state, qualifier = summarize(results)
    ov = overall(results)
    color = _STATE_COLOR.get(state, lambda s: s)
    print(f"{bold(color(state))} — {qualifier}")

    if ov == FAIL:
        if state == "RECOVERING":
            disk_r = _by_name(results, "disk_free") or {}
            cpid = (disk_r.get("data") or {}).get("cleaner_pid")
            pid_str = f" (pid {cpid})" if cpid else ""
            print(f"  → cleanup in progress{pid_str} — wait for it to finish")
        elif state == "PROVISIONING":
            print(f"  → puppet has not finished yet — worker will start once it completes")
        else:
            first_fail = next(r for r in results if r["status"] == FAIL)
            print(f"  → most likely cause: {red(first_fail['name'])} — {first_fail['detail']}")

    w = max(len(r["name"]) for r in results)
    indent = " " * (2 + 1 + 2 + w + 2)  # marker + spacing + name col + spacing
    for r in results:
        s = r["status"]
        if s == PASS:
            marker = "·"
        elif s == WARN:
            marker = yellow("⚠")
        else:
            marker = red("✗")
        print(f"  {marker}  {r['name'].ljust(w)}  {_format_detail(r['detail'])}")
        if s == FAIL:
            hint = REMEDIATIONS.get(r["name"])
            if hint:
                for line in hint.splitlines():
                    print(f"{indent}{yellow('→')} {line}")
        if verbose:
            for cmd in r.get("commands_used") or []:
                print(f"{indent}$ {cmd}")


def main():
    parser = argparse.ArgumentParser(
        description="Read-only health check for Linux Taskcluster generic-worker hosts.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Exit 0 if all checks pass or warn. Exit 1 if any check fails.",
    )
    parser.add_argument("-j", "--json", action="store_true", help="emit JSON report to stdout")
    parser.add_argument("-v", "--verbose", action="store_true", help="show commands used by each check")

    testing = parser.add_argument_group("testing arguments")
    testing.add_argument(
        "--replay", metavar="PATH",
        help="read a prior --json snapshot (or '-' for stdin) and re-render without running checks",
    )
    args = parser.parse_args()

    warnings = []
    if args.replay:
        src = sys.stdin if args.replay == "-" else open(args.replay)
        with src as f:
            snapshot = json.load(f)
        results = snapshot["checks"]
        warnings = snapshot.get("warnings", [])
    else:
        if os.geteuid() != 0:
            warnings.append("not running as root — journalctl checks will return 'unknown' (run with sudo)")
        results = run_checks()
    if args.json:
        print_json(results, warnings, verbose=args.verbose)
    else:
        print_human(results, warnings, verbose=args.verbose)
    sys.exit(0 if overall(results) == PASS else 1)


if __name__ == "__main__":
    main()
